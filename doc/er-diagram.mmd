erDiagram
    Organization ||--o{ Organization : "parent"
    Organization ||--o{ User : "belongs to"
    Organization ||--o{ Building : "manages"
    Organization ||--o{ Project : "manages"
    Building ||--o{ Floor : "has"
    Building ||--o{ Project : "target"
    Project ||--o{ Issue : "contains"
    Floor ||--o{ Issue : "located on"
    Issue ||--o{ Photo : "attached"
    Issue ||--o{ StatusChangeLog : "history"
    User ||--o{ Issue : "reported by"
    User ||--o{ Issue : "assigned to"
    User ||--o{ StatusChangeLog : "changed by"

    Organization {
        uuid organization_id PK
        string name
        string type "Headquarters or Branch"
        uuid parent_id FK "nullable"
        datetime created_at
        datetime updated_at
    }

    User {
        uuid user_id PK
        uuid organization_id FK
        string name
        string email "unique"
        string password_hash
        string role "Admin or Supervisor or Worker"
        boolean is_active "default true"
        datetime created_at
        datetime updated_at
    }

    Building {
        uuid building_id PK
        uuid branch_id FK "Organization Branch"
        string name
        string address
        decimal latitude
        decimal longitude
        string model_urn "APS BIM URN"
        datetime created_at
        datetime updated_at
    }

    Floor {
        uuid floor_id PK
        uuid building_id FK
        string name "1F B1F RF etc"
        int floor_number "sort order"
        datetime created_at
        datetime updated_at
    }

    Project {
        uuid project_id PK
        uuid branch_id FK "Organization Branch"
        uuid building_id FK
        string name
        date start_date
        date due_date
        string status "Planning or Active or Completed"
        datetime created_at
        datetime updated_at
    }

    Issue {
        uuid issue_id PK
        uuid project_id FK
        uuid floor_id FK
        string title
        text description
        string issue_type "Quality Safety Construction Design"
        string status "PointOut Open InProgress Done Confirmed"
        string location_type "DbId or WorldPosition"
        int db_id "nullable Viewer element ID"
        decimal world_position_x "nullable"
        decimal world_position_y "nullable"
        decimal world_position_z "nullable"
        uuid reported_by FK "User Supervisor only"
        uuid assignee_id FK "nullable User Worker"
        date due_date "nullable remediation deadline"
        datetime created_at
        datetime updated_at
    }

    Photo {
        uuid photo_id PK
        uuid issue_id FK
        string blob_key "storage path"
        string photo_phase "Before After Rejection"
        datetime uploaded_at
    }

    StatusChangeLog {
        uuid log_id PK
        uuid issue_id FK
        string from_status "previous status"
        string to_status "new status"
        uuid changed_by FK "User who changed"
        text comment "nullable required on rejection"
        datetime changed_at
    }
