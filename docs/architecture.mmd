    class IssueAggregate,ProjectAggregate,OrganizationEntity,UserEntity,StatusChangeLogEntity,ElementFloorMappingEntity,ValueObjects,RepoInterfaces,StorageInterface,AuthInterface,DomainErrors domainStyle
