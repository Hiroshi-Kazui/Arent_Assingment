graph TB
    subgraph Presentation["Presentation（UI）"]
        Pages["Next.js Pages<br/>プロジェクト一覧 / 3Dビュー<br/>指摘詳細 / 管理画面"]
        Components["UI Components<br/>指摘一覧パネル / 登録フォーム<br/>写真アップロード / 担当者選択"]
        ViewerUI["APS Viewer SDK<br/>3Dモデル表示 / マーカー描画<br/>ピン登録操作"]
        APIRoutes["API Route Handlers<br/>REST エンドポイント"]
        AuthPages["Auth Pages<br/>サインイン / セッション管理"]
    end

    subgraph Application["Application（UseCase）"]
        subgraph Commands["Commands（書き込み）"]
            CreateIssue["CreateIssue"]
            UpdateIssueStatus["UpdateIssueStatus"]
            AddPhoto["AddPhoto"]
            AssignIssue["AssignIssue"]
            DeleteIssue["DeleteIssue"]
            UpdateIssueTitle["UpdateIssueTitle"]
            CreateProject["CreateProject"]
            UpdateProject["UpdateProject"]
            CreateOrganization["CreateOrganization"]
            UpdateOrganization["UpdateOrganization"]
            DeleteOrganization["DeleteOrganization"]
            CreateUser["CreateUser"]
            UpdateUser["UpdateUser"]
            DeactivateUser["DeactivateUser"]
            InitializeModel["InitializeModel"]
        end
        subgraph Queries["Queries（読み取り）"]
            ListProjects["ListProjects"]
            GetProjectDetail["GetProjectDetail"]
            ListIssues["ListIssues"]
            GetIssueDetail["GetIssueDetail"]
            ListBuildings["ListBuildings"]
            ListFloors["ListFloors"]
            GetPhotoUrl["GetPhotoUrl"]
            ListOrganizations["ListOrganizations"]
            ListUsers["ListUsers"]
            ListAssignableUsers["ListAssignableUsers"]
            GetElementFloor["GetElementFloor"]
            GetElementFloorMappings["GetElementFloorMappings"]
        end
        DTO["DTOs"]
    end

    subgraph Domain["Domain（ビジネスルール）"]
        IssueAggregate["Issue 集約ルート<br/>状態遷移ルール<br/>バリデーション"]
        ProjectAggregate["Project 集約"]
        OrganizationEntity["Organization エンティティ<br/>階層管理"]
        UserEntity["User エンティティ<br/>ロール管理"]
        StatusChangeLogEntity["StatusChangeLog エンティティ"]
        ValueObjects["Value Objects<br/>Location / Coordinate"]
        ElementFloorMappingEntity["ElementFloorMapping エンティティ"]
        RepoInterfaces["Repository Interfaces<br/>IIssueRepository<br/>IProjectRepository<br/>IPhotoRepository<br/>IFloorRepository<br/>IBuildingRepository<br/>IOrganizationRepository<br/>IUserRepository<br/>IStatusChangeLogRepository<br/>IElementFloorMappingRepository"]
        StorageInterface["PhotoStorage Interface"]
        AuthInterface["ViewerTokenProvider Interface"]
        DomainErrors["Domain Errors"]
    end

    subgraph Infrastructure["Infrastructure（外部依存）"]
        PrismaRepos["Prisma Repository 実装<br/>PrismaIssueRepository<br/>PrismaProjectRepository<br/>PrismaBuildingRepository<br/>PrismaFloorRepository<br/>PrismaPhotoRepository<br/>PrismaOrganizationRepository<br/>PrismaStatusChangeLogRepository<br/>PrismaElementFloorMappingRepository"]
        MinioStorage["MinIO PhotoStorage 実装"]
        APSToken["APS TokenProvider 実装<br/>2-legged OAuth"]
        DB[("PostgreSQL")]
        Blob[("MinIO<br/>Blob Storage")]
        APS["APS Cloud"]
    end

    %% Presentation → Application
    Pages --> Queries
    Pages --> Components
    Components --> ViewerUI
    APIRoutes --> Commands
    APIRoutes --> Queries
    AuthPages --> APIRoutes

    %% Application → Domain
    Commands --> IssueAggregate
    Commands --> ProjectAggregate
    Commands --> OrganizationEntity
    Commands --> UserEntity
    Commands --> RepoInterfaces
    Commands --> StorageInterface
    Queries --> RepoInterfaces
    Commands --> DTO
    Queries --> DTO

    %% Infrastructure implements Domain interfaces
    RepoInterfaces -.->|implements| PrismaRepos
    StorageInterface -.->|implements| MinioStorage
    AuthInterface -.->|implements| APSToken

    %% Infrastructure → External
    PrismaRepos --> DB
    MinioStorage --> Blob
    APSToken --> APS

